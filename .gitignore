# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but track the placeholders-only template
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# internal / working notes (keep out of the public repo)
CLAUDE.local.md
*.local.md
/notes/

# graphify knowledge graph (local tooling output, may index internal notes)
/graphify-out/

# personal machine-specific Claude Code settings
.claude/settings.local.json
